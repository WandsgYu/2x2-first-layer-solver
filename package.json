{
  "name": "2x2-first-layer-solver",
  "version": "0.1.0",
  "description": "A TypeScript 2x2 Rubik's Cube first layer solver with BFS search, WCA-style scrambles, CLI, and web UI.",
  "keywords": [
    "2x2 cube",
    "rubiks cube",
    "pocket cube",
    "first layer solver",
    "layer solver",
    "cube solver",
    "bfs",
    "wca scramble",
    "typescript",
    "魔方",
    "二阶魔方"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:web": "tsc && vite build",
    "dev": "vite --host 127.0.0.1",
    "test": "npm run build && node --test dist/test/*.test.js",
    "solve": "npm run build && node dist/src/cli.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16"
  }
}
